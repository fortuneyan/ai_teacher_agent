# ============================================================
# AI教师Agent 后端配置模板
# 复制为 .env 并填入真实值后使用
# ============================================================

# ── 应用基本设置 ──────────────────────────────────────────
APP_NAME=AI教师Agent
APP_VERSION=1.0.0
DEBUG=true

# ── PostgreSQL 数据库配置 ─────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ai_teacher_agent
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here

# ── JWT 认证配置 ───────────────────────────────────────────
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AI / LLM 配置（选一个服务商取消注释）─────────────────
# 不填任何值则启用 Mock 模式，无需真实 AI 服务

# OpenAI
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# DeepSeek（推荐，国内直连）
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# 腾讯混元
# LLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_API_BASE=https://api.hunyuan.cloud.tencent.com/v1
# LLM_MODEL=hunyuan-turbo

# 阿里通义千问
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-max

# 字节豆包（火山引擎）
# LLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=ep-你的推理接入点ID

# 智谱 GLM（注册送 token）
# LLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash

# 本地 Ollama（完全本地，免费）
# LLM_API_KEY=ollama
# LLM_API_BASE=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b
